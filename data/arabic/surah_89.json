    "sajdah_number": null,
    "text_uthmani": "فَأَمَّا ٱلْإِنسَـٰنُ إِذَا مَا ٱبْتَلَىٰهُ رَبُّهُۥ فَأَكْرَمَهُۥ وَنَعَّمَهُۥ فَيَقُولُ رَبِّىٓ أَكْرَمَنِ",
    "text_indopak": "فَاَمَّا الۡاِنۡسَانُ اِذَا مَا ابۡتَلٰٮهُ رَبُّهٗ فَاَكۡرَمَهٗ وَنَعَّمَهٗ  ۙ فَيَقُوۡلُ رَبِّىۡۤ اَكۡرَمَنِؕ‏",
    "text_noorehuda": "فَاَمَّا الۡاِنۡسَانُ اِذَا مَا ابۡتَلٰىہُ رَبُّہٗ فَاَکۡرَمَہٗ وَنَعَّمَہٗ ۬ۙ فَیَقُوۡلُ رَبِّیۡۤ اَکۡرَمَنِ ؕ",
    "text_uthmani_simple": "فاما الانسن اذا ما ابتلىه ربه فاكرمه ونعمه فيقول ربى اكرمن",
    "text_qpc_hafs": "فَأَمَّا ٱلۡإِنسَٰنُ إِذَا مَا ٱبۡتَلَىٰهُ رَبُّهُۥ فَأَكۡرَمَهُۥ وَنَعَّمَهُۥ فَيَقُولُ رَبِّيٓ أَكۡرَمَنِ ١٥",
    "text_indopak_nastaleeq": "فَاَمَّا الْاِنْسَانُ اِذَا مَا ابْتَلٰىهُ رَبُّهٗ فَاَكْرَمَهٗ وَنَعَّمَهٗ ۙ۬ فَیَقُوْلُ رَبِّیْۤ اَكْرَمَنِ ۟ؕ",
    "text_qpc_nastaleeq": "فَاَمَّا الْاِنْسَانُ اِذَا مَا ابْتَلٰىهُ رَبُّهٗ فَاَكْرَمَهٗ وَنَعَّمَهٗ ۙ۬ فَیَقُوْلُ رَبِّیْۤ اَكْرَمَنِ ۟ؕ",
