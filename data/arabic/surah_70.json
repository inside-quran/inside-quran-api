    "text_uthmani": "يُبَصَّرُونَهُمْ ۚ يَوَدُّ ٱلْمُجْرِمُ لَوْ يَفْتَدِى مِنْ عَذَابِ يَوْمِئِذٍۭ بِبَنِيهِ",
    "text_indopak": "يُّبَصَّرُوۡنَهُمۡ​ؕ يَوَدُّ الۡمُجۡرِمُ لَوۡ يَفۡتَدِىۡ مِنۡ عَذَابِ يَوۡمِٮِٕذٍۢ بِبَنِيۡهِۙ‏",
    "text_noorehuda": "يُّبَصَّرُوْنَهُمْ ؕ يَوَدُّ الْمُجْرِمُ لَوْ يَفْتَدِيْ مِنْ عَذَابِ يَوْمِئِذٍۭ بِبَنِيْهِ ۙ",
    "text_uthmani_simple": "يبصرونهم يود المجرم لو يفتدى من عذاب يومئذۭ ببنيه",
    "text_qpc_hafs": "يُبَصَّرُونَهُمۡۚ يَوَدُّ ٱلۡمُجۡرِمُ لَوۡ يَفۡتَدِي مِنۡ عَذَابِ يَوۡمِئِذِۭ بِبَنِيهِ ١١",
    "text_indopak_nastaleeq": "یُّبَصَّرُوْنَهُمْ ؕ یَوَدُّ الْمُجْرِمُ لَوْ یَفْتَدِیْ مِنْ عَذَابِ یَوْمِىِٕذٍ بِبَنِیْهِ ۟ۙ",
