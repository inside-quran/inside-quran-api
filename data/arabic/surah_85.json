    "sajdah_number": null,
    "text_uthmani": "ٱلَّذِى لَهُۥ مُلْكُ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ وَٱللَّهُ عَلَىٰ كُلِّ شَىْءٍ شَهِيدٌ",
    "text_indopak": "الَّذِىۡ لَهٗ مُلۡكُ السَّمٰوٰتِ وَالۡاَرۡضِ​ؕ وَ اللّٰهُ عَلٰى كُلِّ شَىۡءٍ شَهِيۡدٌ ؕ‏",
    "text_noorehuda": "الَّذِيْ لَهٗ مُلْكُ السَّمٰوٰتِ وَالْاَرْضِ ؕ وَاللّٰهُ عَلٰي كُلِّ شَيْءٍ شَهِيْدٌ ؕ",
    "text_uthmani_simple": "الذى له ملك السموت والارض والله على كل شىء شهيد",
    "text_qpc_hafs": "ٱلَّذِي لَهُۥ مُلۡكُ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۚ وَٱللَّهُ عَلَىٰ كُلِّ شَيۡءٖ شَهِيدٌ ٩",
    "text_indopak_nastaleeq": "الَّذِیْ لَهٗ مُلْكُ السَّمٰوٰتِ وَالْاَرْضِ ؕ وَاللّٰهُ عَلٰی كُلِّ شَیْءٍ شَهِیْدٌ ۟ؕ",
    "text_qpc_nastaleeq": "الَّذِیْ لَهٗ مُلْكُ السَّمٰوٰتِ وَالْاَرْضِ ؕ وَاللّٰهُ عَلٰی كُلِّ شَیْءٍ شَهِیْدٌ ۟ؕ",
