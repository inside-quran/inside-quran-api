{
  "surahNumber": 101,
  "edition": "hi.hindi",
  "verses": [
    {
      "numberInSurah": 1,
      "text": "खड़खड़ाने वाली"
    },
    {
      "numberInSurah": 2,
      "text": "वह खड़खड़ाने वाली क्या है"
    },
    {
      "numberInSurah": 3,
      "text": "और तुम को क्या मालूम कि वह खड़खड़ाने वाली क्या है"
    },
    {
      "numberInSurah": 4,
      "text": "जिस दिन लोग (मैदाने हश्र में) टिड्डियों की तरह फैले होंगे"
    },
    {
      "numberInSurah": 5,
      "text": "और पहाड़ धुनकी हुई रूई के से हो जाएँगे"
    },
    {
      "numberInSurah": 6,
      "text": "तो जिसके (नेक आमाल) के पल्ले भारी होंगे"
    },
    {
      "numberInSurah": 7,
      "text": "वह मन भाते ऐश में होंगे"
    },
    {
      "numberInSurah": 8,
      "text": "और जिनके आमाल के पल्ले हल्के होंगे"
    },
    {
      "numberInSurah": 9,
      "text": "तो उनका ठिकाना न रहा"
    },
    {
      "numberInSurah": 10,
      "text": "और तुमको क्या मालूम हाविया क्या है"
    },
    {
      "numberInSurah": 11,
      "text": "वह दहकती हुई आग है"
    }
  ]
}