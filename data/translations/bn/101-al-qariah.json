{
  "surahNumber": 101,
  "edition": "bn.bengali",
  "verses": [
    {
      "numberInSurah": 1,
      "text": "করাঘাতকারী,"
    },
    {
      "numberInSurah": 2,
      "text": "করাঘাতকারী কি?"
    },
    {
      "numberInSurah": 3,
      "text": "করাঘাতকারী সম্পর্কে আপনি কি জানেন ?"
    },
    {
      "numberInSurah": 4,
      "text": "যেদিন মানুষ হবে বিক্ষিপ্ত পতংগের মত"
    },
    {
      "numberInSurah": 5,
      "text": "এবং পর্বতমালা হবে ধুনিত রঙ্গীন পশমের মত।"
    },
    {
      "numberInSurah": 6,
      "text": "অতএব যার পাল্লা ভারী হবে,"
    },
    {
      "numberInSurah": 7,
      "text": "সে সুখীজীবন যাপন করবে।"
    },
    {
      "numberInSurah": 8,
      "text": "আর যার পাল্লা হালকা হবে,"
    },
    {
      "numberInSurah": 9,
      "text": "তার ঠিকানা হবে হাবিয়া।"
    },
    {
      "numberInSurah": 10,
      "text": "আপনি জানেন তা কি?"
    },
    {
      "numberInSurah": 11,
      "text": "প্রজ্জ্বলিত অগ্নি!"
    }
  ]
}