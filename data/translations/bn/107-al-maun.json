{
  "surahNumber": 107,
  "edition": "bn.bengali",
  "verses": [
    {
      "numberInSurah": 1,
      "text": "আপনি কি দেখেছেন তাকে, যে বিচারদিবসকে মিথ্যা বলে?"
    },
    {
      "numberInSurah": 2,
      "text": "সে সেই ব্যক্তি, যে এতীমকে গলা ধাক্কা দেয়"
    },
    {
      "numberInSurah": 3,
      "text": "এবং মিসকীনকে অন্ন দিতে উৎসাহিত করে না।"
    },
    {
      "numberInSurah": 4,
      "text": "অতএব দুর্ভোগ সেসব নামাযীর,"
    },
    {
      "numberInSurah": 5,
      "text": "যারা তাদের নামায সম্বন্ধে বে-খবর;"
    },
    {
      "numberInSurah": 6,
      "text": "যারা তা লোক-দেখানোর জন্য করে"
    },
    {
      "numberInSurah": 7,
      "text": "এবং নিত্য ব্যবহার্য্য বস্তু অন্যকে দেয় না।"
    }
  ]
}