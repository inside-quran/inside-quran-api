{
  "surahNumber": 102,
  "edition": "bn.bengali",
  "verses": [
    {
      "numberInSurah": 1,
      "text": "প্রাচুর্যের লালসা তোমাদেরকে গাফেল রাখে,"
    },
    {
      "numberInSurah": 2,
      "text": "এমনকি, তোমরা কবরস্থানে পৌছে যাও।"
    },
    {
      "numberInSurah": 3,
      "text": "এটা কখনও উচিত নয়। তোমরা সত্ত্বরই জেনে নেবে।"
    },
    {
      "numberInSurah": 4,
      "text": "অতঃপর এটা কখনও উচিত নয়। তোমরা সত্ত্বরই জেনে নেবে।"
    },
    {
      "numberInSurah": 5,
      "text": "কখনই নয়; যদি তোমরা নিশ্চিত জানতে।"
    },
    {
      "numberInSurah": 6,
      "text": "তোমরা অবশ্যই জাহান্নাম দেখবে,"
    },
    {
      "numberInSurah": 7,
      "text": "অতঃপর তোমরা তা অবশ্যই দেখবে দিব্য প্রত্যয়ে,"
    },
    {
      "numberInSurah": 8,
      "text": "এরপর অবশ্যই সেদিন তোমরা নেয়ামত সম্পর্কে জিজ্ঞাসিত হবে।"
    }
  ]
}