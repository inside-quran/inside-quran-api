{
  "surahNumber": 74,
  "edition": "ur.roman",
  "verses": [
    {
      "numberInSurah": 1,
      "text": "Aey oad lapeit (enveloped) kar laitney waley"
    },
    {
      "numberInSurah": 2,
      "text": "Utho aur khabardar karo"
    },
    {
      "numberInSurah": 3,
      "text": "Aur apne Rubb ki badayi ka elan karo"
    },
    {
      "numberInSurah": 4,
      "text": "Aur apne kapde paak rakho"
    },
    {
      "numberInSurah": 5,
      "text": "Aur gandagi se dur raho"
    },
    {
      "numberInSurah": 6,
      "text": "Aur ehsan na karo zyada hasil karne keliye"
    },
    {
      "numberInSurah": 7,
      "text": "Aur apne Rubb ki khatir sabr karo"
    },
    {
      "numberInSurah": 8,
      "text": "Accha jab soor mein phook maari jayegi"
    },
    {
      "numberInSurah": 9,
      "text": "Woh din bada hi sakht din hoga"
    },
    {
      "numberInSurah": 10,
      "text": "Kafiron ke liye halka na hoga"
    }
  ]
}