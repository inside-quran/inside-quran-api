{
  "surahNumber": 99,
  "edition": "verse.transliteration",
  "verses": [
    {
      "numberInSurah": 1,
      "text": "Izaa zul zilatil ardu zil zaalaha"
    },
    {
      "numberInSurah": 2,
      "text": "Wa akh rajatil ardu athqaalaha"
    },
    {
      "numberInSurah": 3,
      "text": "Wa qaalal insaanu ma laha"
    },
    {
      "numberInSurah": 4,
      "text": "Yawmaa izin tuhad dithu akhbaaraha"
    },
    {
      "numberInSurah": 5,
      "text": "Bi-anna rabbaka awhaa laha"
    },
    {
      "numberInSurah": 6,
      "text": "Yawma iziy yas durun naasu ash tatal liyuraw a'maalahum"
    },
    {
      "numberInSurah": 7,
      "text": "Famaiy ya'mal mithqala zarratin khai raiy-yarah"
    },
    {
      "numberInSurah": 8,
      "text": "Wa maiy-y'amal mithqala zarratin sharraiy-yarah"
    }
  ]
}